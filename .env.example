# ============================================================================
# HireFlow CascadeFlow Backend — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================================

# ---------------------------------------------------------------------------
# Groq API (REQUIRED)
# ---------------------------------------------------------------------------
# Obtain your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------------------------------
# Groq Models (multi-model routing)
# ---------------------------------------------------------------------------
# These models must be available in your Groq account.
# Simple inputs  → GROQ_MODEL_SIMPLE  (fast, cheap)
# Complex inputs → GROQ_MODEL_COMPLEX (powerful, higher cost)
GROQ_MODEL_SIMPLE=llama-3.1-8b-instant
GROQ_MODEL_COMPLEX=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# CascadeFlow Harness
# ---------------------------------------------------------------------------

# Harness mode: off | observe | enforce
#   off      — CascadeFlow disabled, zero overhead
#   observe  — Track all calls, log decisions, no enforcement
#   enforce  — Active governance (budget caps, model switching, stop actions)
CASCADEFLOW_MODE=observe

# Default budget cap per session in USD (used when request doesn't specify one)
CASCADEFLOW_DEFAULT_BUDGET=1.00

# Enable audit logging at every decision boundary
CASCADEFLOW_ENABLE_AUDIT=true

# Enable cumulative cost tracking per session
CASCADEFLOW_ENABLE_COST_TRACKING=true

# Enable complexity-based model routing (simple → small model, complex → large model)
CASCADEFLOW_ENABLE_SEMANTIC_ROUTING=true

# Optional: Compliance framework (gdpr, hipaa, soc2, etc.)
# CASCADEFLOW_COMPLIANCE=gdpr

# ---------------------------------------------------------------------------
# FastAPI Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
